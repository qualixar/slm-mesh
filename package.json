{
  "name": "slm-mesh",
  "version": "1.2.0",
  "description": "Peer-to-peer communication for AI coding agents — by Qualixar, powered by SuperLocalMemory",
  "author": "Varun Pratap Bhardwaj",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "slm-mesh": "./dist/index.js"
  },
  "files": [
    "dist",
    "skills",
    "scripts",
    "integrations",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "postinstall": "node scripts/postinstall.mjs 2>/dev/null || true",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^11.9.1",
    "commander": "^14.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.3",
    "@vitest/coverage-v8": "^3.1.2",
    "tsup": "^8.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "mcp",
    "ai-agents",
    "peer-to-peer",
    "claude-code",
    "cursor",
    "aider",
    "codex",
    "qualixar",
    "superlocalmemory",
    "inter-session",
    "communication"
  ],
  "homepage": "https://github.com/qualixar/slm-mesh",
  "repository": {
    "type": "git",
    "url": "https://github.com/qualixar/slm-mesh.git"
  }
}
